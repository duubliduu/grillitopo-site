generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Feedback {
  id        String   @id @default(cuid())
  youtubeId String
  content   String
  rating    Int      @default(50)
  email     String?
  name      String?
  createdAt DateTime @default(now())
}
